button.select(
    type="button"
    ng-click="displayOptions()"
)
    span.swimlane-select-text(ng-if="currentSwimlane")
        span {{currentSwimlane.name}}
        span.swimlane-default(ng-if="currentSwimlane.id == userStory.swimlane && swimlanes.size > 1") ({{"LIGHTBOX.CREATE_EDIT.DEFAULT" | translate}})
    span.swimlane-select-text.unclassified(ng-if="!currentSwimlane") {{ "KANBAN.UNCLASSIFIED_USER_STORIES" | translate }}
    tg-svg(svg-icon="icon-arrow-down")
.options(
    ng-show="displaySelector"
    ng-mouseleave="hideOptions()"
    ng-mouseenter="displayOptions()"
)
    button.option(
        type="button"
        tg-repeat="swimlane in swimlanes"
        ng-class="{'selected': swimlane.id == currentSwimlaneId || swimlane.id == -1 && !currentSwimlaneId, 'unclassified': swimlane.id == -1}"
        ng-click="selectSwimlane(swimlane)"
    )
        span {{ swimlane.name }}
        span.swimlane-default(ng-if="userStory.swimlane == swimlane.id && swimlanes.size > 1") ({{"LIGHTBOX.CREATE_EDIT.DEFAULT" | translate}})
